# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — server-only, used by /api/capture, /api/metrics and cron jobs.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# UUID of the single user (auth.users.id). Find it in Supabase > Authentication.
LIFEOS_USER_ID=00000000-0000-0000-0000-000000000000

# --- Anthropic (capture parsing) ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Shared secrets ------------------------------------------------------------
# Bearer token the iOS Shortcut sends to POST /api/capture and /api/metrics.
CAPTURE_TOKEN=generate-a-long-random-string
# Bearer token your cron scheduler sends to GET /api/cron.
CRON_SECRET=generate-another-long-random-string

# --- Pushover (notifications) -------------------------------------------------
PUSHOVER_TOKEN=your-app-token
PUSHOVER_USER=your-user-key

# --- Google Calendar (read-only, optional) ------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- App ----------------------------------------------------------------------
LIFEOS_TIMEZONE=Europe/London
